        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const text = [\"Desk Pen Holder\", \"Ceramic Candy Bowl\", \"Ceramic Coffee Cup\"]\r",
              "\r",
              "function getRandomIntNumber(min, max) {\r",
              "    const minCeiled = Math.ceil(min);\r",
              "    const maxFloored = Math.floor(max);\r",
              "    return Math.floor(Math.random() * (maxFloored - minCeiled + 1)) + minCeiled;\r",
              "}\r",
              "\r",
              "const index = getRandomIntNumber(0, 2)\r",
              "const searchedText = text[index]\r",
              "pm.collectionVariables.set(\"searched_text\", searchedText);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseBody = pm.response.json();\r",
              "const searchedText = pm.collectionVariables.get(\"searched_text\");\r",
              "\r",
              "pm.test(\"Validate status code is 200\", () => {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "})\r",
              "\r",
              "pm.test(\"Validate success value is true\", () => {\r",
              "    pm.expect(responseBody.success).to.eql(true);\r",
              "})\r",
              "\r",
              "const items = responseBody.eContext.graphqlResponse.eqg118nmnimiekh.products.items;\r",
              "for(let i=0; i< items.length; i++){\r",
              "    console.log(items[i].name)\r",
              "    pm.test(`Validate searched text within ${items[i].name}`, () => {\r",
              "        pm.expect(items[i].name).to.contain(searchedText);\r",
              "    })\r",
              "}\r",
              "\r",
              "function getRandomIntNumber(min, max) {\r",
              "    const minCeiled = Math.ceil(min);\r",
              "    const maxFloored = Math.floor(max);\r",
              "    return Math.floor(Math.random() * (maxFloored - minCeiled + 1)) + minCeiled;\r",
              "}\r",
              "\r",
              "const index = getRandomIntNumber(0, items.length - 1);\r",
              "const sku = items[index].sku;\r",
              "console.log(`Product sku :${sku}`);\r",
              "pm.collectionVariables.set(\"product_sku\",sku);\r",
              "\r",
              "const price = responseBody.eContext.graphqlResponse.eqg118nmnimiekh.products.items[index].price.regular;\r",
              "const value = items[index].price.regular.value;\r",
              "console.log(`Product price :${value}`);\r",
              "pm.collectionVariables.set(\"product_price\",value);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
